NODE_ENV=production
API_ORIGIN=https://smoveapi-1.onrender.com
FRONTEND_ORIGINS=https://smoovecms.vercel.app,https://www.smovecommunication.com

MONGO_URI=
MONGO_DB_NAME=smoveqpp

SESSION_SECRET=
AUTH_STORAGE_MODE=mongo
SESSION_STORE_MODE=mongo
SESSION_TTL_SECONDS=86400

# Public email/password auth. Registration creates only client or user roles.
ENABLE_EMAIL_PASSWORD_AUTH=true
PUBLIC_REGISTRATION_ENABLED=true
DEFAULT_PUBLIC_ROLE=client

ENABLE_GOOGLE_LOGIN=false
ENABLE_FACEBOOK_LOGIN=false

# Cloudinary media source of truth
MEDIA_STORAGE_DRIVER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=smove

# Contact email delivery (message persistence works without these)
CONTACT_TO_EMAIL=
EMAIL_FROM=SMOVE <noreply@example.com>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
